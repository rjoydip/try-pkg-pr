{
  "name": "try-pkg-pr",
  "version": "0.1.0",
  "description": "A Bun-based app for testing pkg.pr.new continuous preview releases",
  "bin": {
    "try-pkg-pr": "./dist/cli.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "bun run src/index.ts",
    "cli": "bun run src/cli.ts",
    "build": "bun build src/index.ts --outfile dist/index.js",
    "build:cli": "bun build src/cli.ts --compile --outfile dist/cli.js",
    "build:all": "bun run build && bun run build:cli",
    "test": "bun test",
    "typecheck": "bun tsc --noEmit",
    "lint": "oxlint . --format=github",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "publish:preview": "npx pkg-pr-new publish --packageManager=bun --comment=update",
    "publish:preview:sha": "npx pkg-pr-new publish --packageManager=bun --comment=update --commentWithSha",
    "actions-up": "actions-up",
    "fallow": "fallow",
    "fallow:dead": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health --format badge > .artifacts/fallow-health.svg; exit 0"
  },
  "dependencies": {},
  "devDependencies": {
    "actions-up": "^1.14.3",
    "bun-types": "^1.3.14",
    "fallow": "^2.102.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.70.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint && bun run format:check && bun run typecheck"
  }
}
